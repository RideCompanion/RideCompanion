@using Microsoft.AspNetCore.Mvc.TagHelpers
@model User.Domain.Dto.SignUpDto

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<div class="min-w-screen flex min-h-screen items-center justify-center">
    <div class="w-full max-w-sm space-y-6 rounded-lg border border-gray-200 bg-white p-4 shadow dark:border-gray-700 dark:bg-gray-800 sm:p-6 md:p-8">
        <section>
            <form id="SignUp" asp-action="SignUp" method="post" class="space-y-6">
                <h2 class="text-xl font-medium text-gray-900 dark:text-white">Create a new account</h2>
                <hr/>
                <div asp-validation-summary="ModelOnly" class="" role="alert"></div>
                <div class="">
                    <label asp-for="Email" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                        Your email
                    </label>
                    <input asp-for="Email" id="email" class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500 dark:border-gray-500 dark:bg-gray-600 dark:text-white dark:placeholder-gray-400" autocomplete="username" aria-required="true" placeholder="name@example.com"/>
                    <span asp-validation-for="Email" class=""></span>
                </div>
                <div class="">
                    <label asp-for="Password" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                        Password
                    </label>
                    <input asp-for="Password" id="password" class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500 dark:border-gray-500 dark:bg-gray-600 dark:text-white dark:placeholder-gray-400" autocomplete="new-password" aria-required="true" placeholder="password"/>
                    <span asp-validation-for="Password" class=""></span>
                </div>
                <div class="">
                    <label asp-for="ConfirmPassword" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                        Confirm Password
                    </label>
                    <input asp-for="ConfirmPassword" id="confirm-password" class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-500 focus:ring-blue-500 dark:border-gray-500 dark:bg-gray-600 dark:text-white dark:placeholder-gray-400" autocomplete="new-password" aria-required="true" placeholder="password"/>
                    <span asp-validation-for="ConfirmPassword" class=""></span>
                </div>
                <div class="flex w-full flex-row space-x-2">
                    <button id="signIn" asp-action="SignIn" class="mr-2 mb-2 w-1/2 rounded-lg border border-blue-700 px-5 py-2.5 text-center text-sm font-medium text-blue-700 hover:bg-blue-800 hover:text-white focus:outline-none focus:ring-4 focus:ring-blue-300 dark:border-blue-500 dark:text-blue-500 dark:hover:bg-blue-600 dark:hover:text-white dark:focus:ring-blue-800">
                        Sign In
                    </button>
                    <button id="registerSubmit" type="submit" class="mr-2 mb-2 w-1/2 rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                        Create account
                    </button>
                </div>
            </form>
        </section>
    </div>
</div>
